# Local Terraform directories
.terraform/
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate.d/

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.sample

# Terraform plan output
*.tfplan
*.plan
plan.out

# Terraform crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Logs
*.log

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
